# Application Settings
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# JWT Settings
JWT_SECRET_KEY=release_secret_key_replace_me

# MongoDB Settings
MONGODB_URI=mongodb://mongodb:27017/epita

# PostgreSQL Settings
DB_HOST=postgres
DB_PORT=5432
DB_NAME=movies
DB_USER=postgres
DB_PASSWORD=postgres_release_pwd

# Timeouts and Limits
REQUEST_TIMEOUT=5000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100